{
  "name": "r-rag",
  "version": "0.1.0",
  "description": "LLM-driven hierarchical knowledge system using reasoning instead of embeddings",
  "license": "MIT",
  "author": {
    "name": "YANG Zi Han",
    "email": "yuansasi@outlook.com",
    "url": "https://www.yangzihan.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YuanSa/rRAG.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/YuanSa/rRAG",
  "bugs": {
    "url": "https://github.com/YuanSa/rRAG/issues"
  },
  "keywords": [
    "cli",
    "knowledge-base",
    "rag",
    "llm",
    "agents",
    "filesystem"
  ],
  "type": "module",
  "bin": {
    "rrag": "./bin/rrag.js"
  },
  "files": [
    "bin",
    "gui",
    "src",
    "docs",
    "examples",
    "scripts",
    "package.json",
    "LICENSE"
  ],
  "scripts": {
    "start": "node ./bin/rrag.js",
    "gui": "node ./bin/rrag.js gui",
    "gui:dev": "vite --config ./gui/vite.config.js",
    "build:gui": "vite build --config ./gui/vite.config.js",
    "prepack": "npm run build:gui",
    "check": "node ./bin/rrag.js --help",
    "demo:testcases": "node ./scripts/run-test-cases.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@douyinfe/semi-icons": "^2.93.0",
    "@douyinfe/semi-ui": "^2.93.0",
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.5"
  }
}
